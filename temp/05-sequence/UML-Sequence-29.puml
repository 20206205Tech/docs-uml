@startuml
actor "User" as User
participant "Web Frontend" as Frontend
participant "API Gateway\n(Kong)" as Kong
participant "Payment Service" as PaymentService
participant "Payment DB" as DB
participant "Redis (BullMQ)" as Redis
participant "Payment Gateway\n(VNPay/MoMo)" as Gateway

== Pha 1: Khởi tạo giao dịch mua gói VIP ==

User -> Frontend: Chọn mua gói VIP\n(Click "Nâng cấp VIP")
activate Frontend
Frontend -> Kong: POST /code-payment-service/subscriptions/purchase\n[Authorization: Bearer <token>]\n{ plan_id, redirect_url }
activate Kong
Kong -> PaymentService: Chuyển tiếp yêu cầu mua gói
activate PaymentService

PaymentService -> DB: Query Plan bằng plan_id
activate DB
DB --> PaymentService: Trả về thông tin gói cước
deactivate DB

PaymentService -> DB: Query Subscription bằng userId
activate DB
DB --> PaymentService: Trả về Subscription hiện tại nếu có
deactivate DB

PaymentService -> DB: UPSERT Subscription\n(status='PENDING')
activate DB
DB --> PaymentService: OK
deactivate DB

PaymentService -> DB: INSERT Transaction\n(status='PENDING', txnRef, finalAmount)
activate DB
DB --> PaymentService: OK
deactivate DB

PaymentService -> Redis: Đăng ký job timeout\n(delay = 15 phút)
activate Redis
Redis --> PaymentService: OK
deactivate Redis

PaymentService -> Gateway: Gọi API tạo link thanh toán\n(amount, description, txnRef)
activate Gateway
Gateway --> PaymentService: Trả về Payment URL
deactivate Gateway

PaymentService --> Kong: HTTP 201\n{ payment_url }
deactivate PaymentService
Kong --> Frontend: Trả về payment_url
deactivate Kong
Frontend --> User: Chuyển hướng đến Payment Gateway URL
deactivate Frontend
@enduml
