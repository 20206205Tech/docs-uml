@startuml
actor "Guest" as Guest
participant "Web Frontend" as Frontend
participant "API Gateway\n(Kong)" as Gateway
participant "Payment Service" as PaymentService
participant "Persona Service" as PersonaService

== Luồng Xem trang chủ (Giới thiệu, Bảng giá, Nhân vật) ==
Guest -> Frontend: Truy cập Trang chủ
activate Frontend

par #LightCyan Lấy dữ liệu song song
    Frontend -> Gateway: Lấy thông tin gói cước
    activate Gateway
    Gateway -> PaymentService: Lấy danh sách gói cước
    activate PaymentService
    PaymentService --> Gateway: Danh sách gói cước
    deactivate PaymentService
    Gateway --> Frontend: Trả về thông tin gói cước
    deactivate Gateway
else #LightYellow
    Frontend -> Gateway: Lấy danh sách nhân vật
    activate Gateway
    Gateway -> PersonaService: Lấy danh sách nhân vật
    activate PersonaService
    PersonaService --> Gateway: Danh sách nhân vật
    deactivate PersonaService
    Gateway --> Frontend: Trả về danh sách nhân vật
    deactivate Gateway
end

Frontend --> Guest: Hiển thị trang chủ (Giới thiệu, Bảng giá, Nhân vật)
deactivate Frontend
@enduml
